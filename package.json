{
  "name": "voxel-shooter",
  "version": "1.0.271",
  "type": "commonjs",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "build": "vite build",
    "prepack": "node scripts/copy-icon.js",
    "predist": "node scripts/copy-icon.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "version": "echo Current version: $npm_package_version"
  },
  "dependencies": {
    "electron": "^26.2.0",
    "simplex-noise": "^4.0.3",
    "three": "^0.162.0",
    "voxel": "^0.5.0"
  },
  "devDependencies": {
    "electron-builder": "^25.1.8",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.voxel-shooter.game",
    "productName": "MystOracle: Age of the Firstborn",
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}